/*左右渐变遮罩*/
.swiper-box.data-v-a0f6c002 {
  flex: 1;
}
.swiper-item.data-v-a0f6c002 {
  height: 100%;
}
/*scroll-view外层*/
.skill-sequence-panel-content-wrapper.data-v-a0f6c002 {
  position: relative;
  white-space: nowrap;
  padding: 10rpx 0 10rpx 10rpx;
}
.hide-content-box.data-v-a0f6c002 {
  position: absolute;
  top: 0;
  height: 100%;
  width: 10px;
  z-index: 2;
}
.hide-content-box-left.data-v-a0f6c002 {
  left: 0;
  background-image: linear-gradient(to left, rgba(255, 255, 255, 0), #f3f3f3 60%);
}
.hide-content-box-right.data-v-a0f6c002 {
  right: 0;
  background-image: linear-gradient(to right, rgba(255, 255, 255, 0), #f3f3f3 60%);
}
.kite-classify-scroll.data-v-a0f6c002 {
  width: 100%;
  height: 90rpx;
  overflow: hidden;
  white-space: nowrap;
}
.topoc-wrap.data-v-a0f6c002 {
  position: relative;
  display: inline-block;
  width: calc((100% / 4) - 30rpx);
  height: 90rpx;
  margin-right: 20rpx;
  background-color: #FFFFFF;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 2px 2px 3px rgba(26, 26, 26, 0.2);
}
.topoc-wrap image.data-v-a0f6c002 {
  position: absolute;
  top: 0;
  left: 0;
}
.topoc-wrap .nav-content.data-v-a0f6c002 {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 10rpx 15rpx;
  flex-wrap: wrap;
  overflow: hidden;
  white-space: normal;
  color: #fff;
  letter-spacing: 3rpx;
  font-weight: 400;
  font-size: 22rpx;
  background-color: rgba(0, 0, 0, 0.4);
}

