<view class="wrap data-v-61faf6ef"><view class="comment data-v-61faf6ef"><view class="top data-v-61faf6ef"><view class="left data-v-61faf6ef"><view class="user_photo data-v-61faf6ef"><image src="{{comment.url}}" mode class="data-v-61faf6ef"></image></view><view class="user_info data-v-61faf6ef"><view class="name data-v-61faf6ef">{{comment.name}}</view><view class="date data-v-61faf6ef">{{comment.date}}</view></view></view></view><view class="content data-v-61faf6ef">{{comment.contentText}}</view></view><view class="all-reply data-v-61faf6ef"><view class="all-reply-top data-v-61faf6ef">{{"全部回复（"+comment.allReply+"）"}}</view><block wx:for="{{commentList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="item data-v-61faf6ef"><view class="comment data-v-61faf6ef"><view class="top data-v-61faf6ef"><view class="left data-v-61faf6ef"><view class="user_photo data-v-61faf6ef"><image src="{{comment.url}}" mode class="data-v-61faf6ef"></image></view><view class="user_info data-v-61faf6ef"><view class="name data-v-61faf6ef">{{item.name}}</view><view class="date data-v-61faf6ef">{{item.data}}</view></view></view><view class="right data-v-61faf6ef"><block wx:if="{{!item.isLikes}}"><u-icon class="like data-v-61faf6ef" vue-id="{{'45373012-1-'+index}}" name="thumb-up" color="#9a9a9a" size="{{40}}" data-event-opts="{{[['^click',[['getLike',[index]]]]]}}" bind:click="__e" bind:__l="__l"></u-icon></block><block wx:if="{{item.isLikes}}"><u-icon class="like data-v-61faf6ef" style="color:#FBBD08;" vue-id="{{'45373012-2-'+index}}" name="thumb-up-fill" size="{{40}}" data-event-opts="{{[['^click',[['getLike',[index]]]]]}}" bind:click="__e" bind:__l="__l"></u-icon></block><view class="num data-v-61faf6ef">{{item.likeNum}}</view></view></view><view class="content data-v-61faf6ef">{{item.contentText}}</view><block wx:if="{{item.reply}}"><view class="reply data-v-61faf6ef"><view class="username data-v-61faf6ef">{{comment.name}}<image src="../../static/Homer.jpg" mode="aspect